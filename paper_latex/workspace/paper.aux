\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces PRMP vs.\ Standard aggregation across 8 RelBench tasks. Cohen's $d$ is positive when PRMP outperforms Standard. Bold indicates the largest effect per task type.}}{6}{table.1}\protected@file@percent }
