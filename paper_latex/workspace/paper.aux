\newlabel{sec:embedding}{{4.5}{9}{Embedding-Space Predictability Analysis}{subsection.4.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces PRMP improvement ($\Delta $ = Standard metric $-$ PRMP metric, positive favors PRMP) across four loss function configurations on the F1 dataset (13 seeds each). Regression losses (MAE, MSE) yield mean PRMP improvement of $+0.43$ while classification losses (CE, BCE) yield $-0.05$ (two-sample $t$-test: $t = 2.74$, $p = 0.008$). The result demonstrates that the loss function, not the target variable nature, mediates PRMP's effectiveness.}}{10}{figure.4}\protected@file@percent }
\newlabel{fig:loss_swap}{{4}{10}{PRMP improvement ($\Delta $ = Standard metric $-$ PRMP metric, positive favors PRMP) across four loss function configurations on the F1 dataset (13 seeds each). Regression losses (MAE, MSE) yield mean PRMP improvement of $+0.43$ while classification losses (CE, BCE) yield $-0.05$ (two-sample $t$-test: $t = 2.74$, $p = 0.008$). The result demonstrates that the loss function, not the target variable nature, mediates PRMP's effectiveness}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Cross-table predictability (Ridge $R^2$) measured in raw features versus learned GNN embeddings during training on Amazon Video Games. Raw-feature $R^2$ is near zero for both FK links (dashed lines), but embedding-space $R^2$ rises substantially during training, reaching 0.44 for product-to-review and 0.69 for customer-to-review. This embedding predictability gap demonstrates that GNNs learn cross-table structure invisible to static feature diagnostics.}}{10}{figure.5}\protected@file@percent }
\newlabel{fig:embedding_pred}{{5}{10}{Cross-table predictability (Ridge $R^2$) measured in raw features versus learned GNN embeddings during training on Amazon Video Games. Raw-feature $R^2$ is near zero for both FK links (dashed lines), but embedding-space $R^2$ rises substantially during training, reaching 0.44 for product-to-review and 0.69 for customer-to-review. This embedding predictability gap demonstrates that GNNs learn cross-table structure invisible to static feature diagnostics}{figure.5}{}}
